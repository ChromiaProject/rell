@test module;
import ^^^.dip.*;

function test_map_definition() {
	var types = MapTypes(K = a_type.text, V= a_type.integer);
	Interface_("ITest", ["map": Type(Map(types))]).run();
	
	types = MapTypes(K = a_type.integer, V= a_type.byte_array);
	Interface_("ITest2", ["map": Type(Map(types))]).run();
}

function test_map_definition_disallowed_key() {
	var types = MapTypes(K = a_type.decimal, V= a_type.integer);
	Interface_("ITest", ["map": Type(Map(types))]).run_must_fail();
	
	types = MapTypes(K = a_type.ordered_container, V= a_type.integer);
	Interface_("ITest", ["map": Type(Map(types))]).run_must_fail();
	
	types = MapTypes(K = a_type.meta, V= a_type.integer);
	Interface_("ITest", ["map": Type(Map(types))]).run_must_fail();
	
	types = MapTypes(K = a_type.id, V= a_type.integer);
	Interface_("ITest", ["map": Type(Map(types))]).run_must_fail();
}

function test_map_initialization() {
	val types = MapTypes(K = a_type.text, V= a_type.integer);
	Interface_("ITest", ["map": Type(Map(types))]).run();
	
	val m = ["test".to_gtv(): integer(42).to_gtv()];
	Instance_(["ITest"], ["map": Map(value=m)]).run();
}

function test_map_initialization_wrong_type() {
	val types = MapTypes(K = a_type.text, V= a_type.integer);
	Interface_("ITest", ["map": Type(Map(types))]).run();
	
	var m = ["test".to_gtv(): "test".to_gtv()];
	Instance_(["ITest"], ["map": Map(value=m)]).run_must_fail();
	
	m = [integer(42).to_gtv(): "test".to_gtv()];
	Instance_(["ITest"], ["map": Map(value=m)]).run_must_fail();
}

function test_map_put() {
	val types = MapTypes(K = a_type.text, V= a_type.integer);
	Interface_("ITest", ["map": Type(Map(types))]).run();
	
	var m = ["test".to_gtv(): integer(21).to_gtv()];
	Instance_(["ITest"], ["map": Map(value=m)]).run();
	
	val i = get_last_instance();
	val a = get_attribute_by_dclass_name("ITest", "map");
	assert_equals(map_sizeof(i, a), 1);
	
	assert_false(map_contains_key(i, a, "test2".to_gtv()));
	map_put_(i, a, ("test2".to_gtv(), integer(42).to_gtv())).run();
	assert_true(map_contains_key(i, a, "test2".to_gtv()));
	
	assert_equals(map_sizeof(i, a), 2);
}

function test_map_put_on_empty() {
	val types = MapTypes(K = a_type.text, V= a_type.integer);
	Interface_("ITest", ["map": Type(Map(types))]).run();
	
	Instance_(["ITest"], ["map": Map(value=map<gtv,gtv>())]).run();
	
	val i = get_last_instance();
	val a = get_attribute_by_dclass_name("ITest", "map");
	assert_true(map_empty(i, a));
	
	assert_false(map_contains_key(i, a, "test".to_gtv()));
	map_put_(i, a, ("test".to_gtv(), integer(42).to_gtv())).run();
	assert_true(map_contains_key(i, a, "test".to_gtv()));
	
	assert_equals(map_sizeof(i, a), 1);
}

function test_map_put_all() {
	val types = MapTypes(K = a_type.text, V= a_type.integer);
	Interface_("ITest", ["map": Type(Map(types))]).run();
	
	var m = ["test".to_gtv(): integer(21).to_gtv()];
	Instance_(["ITest"], ["map": Map(value=m)]).run();
	
	val i = get_last_instance();
	val a = get_attribute_by_dclass_name("ITest", "map");
	assert_equals(map_sizeof(i, a), 1);
	
	assert_false(map_contains_key(i, a, "test3".to_gtv()));
	m = [
		"test2".to_gtv(): integer(2).to_gtv(),
		"test3".to_gtv(): integer(3).to_gtv(),
		"test4".to_gtv(): integer(4).to_gtv(),
		"test5".to_gtv(): integer(5).to_gtv()
	];
	map_put_all_(i, a, m).run();
	assert_true(map_contains_key(i, a, "test3".to_gtv()));
	
	assert_equals(map_sizeof(i, a), 5);
}

function test_map_put_all_on_empty() {
	val types = MapTypes(K = a_type.text, V= a_type.integer);
	Interface_("ITest", ["map": Type(Map(types))]).run();
	
	Instance_(["ITest"], ["map": Map(value=map<gtv,gtv>())]).run();
	
	val i = get_last_instance();
	val a = get_attribute_by_dclass_name("ITest", "map");
	assert_true(map_empty(i, a));
	
	assert_false(map_contains_key(i, a, "test3".to_gtv()));
	val m = [
		"test1".to_gtv(): integer(1).to_gtv(),
		"test2".to_gtv(): integer(2).to_gtv(),
		"test3".to_gtv(): integer(3).to_gtv(),
		"test4".to_gtv(): integer(4).to_gtv()
	];
	map_put_all_(i, a, m).run();
	assert_true(map_contains_key(i, a, "test3".to_gtv()));
	
	assert_equals(map_sizeof(i, a), 4);
}

function test_map_put_same_key() {
	val types = MapTypes(K = a_type.text, V= a_type.integer);
	Interface_("ITest", ["map": Type(Map(types))]).run();
	
	val a = get_attribute_by_dclass_name("ITest", "map");
	
	var m = ["test".to_gtv(): integer(21).to_gtv()];
	Instance_(["ITest"], ["map": Map(value=m)]).run();
	
	val i = get_last_instance();
	
	assert_equals(map_sizeof(i, a), 1);
	
	map_put_(i, a, ("test".to_gtv(), integer(42).to_gtv())).run();
	
	assert_equals(map_sizeof(i, a), 1);
}

function test_map_put_all_same_key() {
	val types = MapTypes(K = a_type.text, V= a_type.integer);
	Interface_("ITest", ["map": Type(Map(types))]).run();
	
	var m = ["test".to_gtv(): integer(21).to_gtv()];
	Instance_(["ITest"], ["map": Map(value=m)]).run();
	
	val i = get_last_instance();
	val a = get_attribute_by_dclass_name("ITest", "map");
	m = [
		"test".to_gtv(): integer(2).to_gtv(),
		"test3".to_gtv(): integer(3).to_gtv(),
		"test4".to_gtv(): integer(4).to_gtv(),
		"test5".to_gtv(): integer(5).to_gtv()
	];
	map_put_all_(i, a, m).run();
	
	assert_equals(map_sizeof(i, a), 4);
}

function test_map_put_multiple_instances() {
	val types = MapTypes(K = a_type.text, V= a_type.integer);
	Interface_("ITest", ["map": Type(Map(types))]).run();
	
	val a = get_attribute_by_dclass_name("ITest", "map");	
	
	var m = ["test".to_gtv(): integer(21).to_gtv()];
	Instance_(["ITest"], ["map": Map(value=m)]).run();
	val i1 = get_last_instance();
	
	m = ["test".to_gtv(): integer(42).to_gtv()];
	Instance_(["ITest"], ["map": Map(value=m)]).run();
	val i2 = get_last_instance();
	
	m = ["test".to_gtv(): integer(137).to_gtv()];
	Instance_(["ITest"], ["map": Map(value=m)]).run();
	val i3 = get_last_instance();
	
	assert_equals(map_sizeof(i1, a), 1);
	assert_equals(map_sizeof(i2, a), 1);
	assert_equals(map_sizeof(i3, a), 1);
	
	map_put_(i2, a, ("test2".to_gtv(), integer(42).to_gtv())).run();
	m = [
		"test2".to_gtv(): integer(2).to_gtv(),
		"test3".to_gtv(): integer(3).to_gtv(),
		"test4".to_gtv(): integer(4).to_gtv(),
		"test5".to_gtv(): integer(5).to_gtv()
	];
	map_put_all_(i3, a, m).run();
	
	assert_equals(map_sizeof(i1, a), 1);
	assert_equals(map_sizeof(i2, a), 2);
	assert_equals(map_sizeof(i3, a), 5);
	
	assert_false(map_contains_key(i1, a, "test2".to_gtv()));
	assert_false(map_contains_key(i2, a, "test3".to_gtv()));
	assert_true(map_contains_key(i3, a, "test3".to_gtv()));
}

function test_map_remove() {
	val types = MapTypes(K = a_type.text, V= a_type.integer);
	Interface_("ITest", ["map": Type(Map(types))]).run();
	
	val m = [
		"test".to_gtv(): integer(42).to_gtv(),
		"test2".to_gtv(): integer(21).to_gtv()
	];
	Instance_(["ITest"], ["map": Map(value=m)]).run();
	
	val i = get_last_instance();
	val a = get_attribute_by_dclass_name("ITest", "map");
	
	assert_equals(map_sizeof(i, a), 2);
	
	assert_true(map_contains_key(i, a, "test2".to_gtv()));
	map_remove_(i, a, "test2".to_gtv()).run();
	assert_equals(map_sizeof(i, a), 1);	
	assert_false(map_contains_key(i, a, "test2".to_gtv()));
	
	map_remove_(i, a, "test3".to_gtv()).run_must_fail();	
	map_remove_(i, a, integer(1).to_gtv()).run_must_fail();
	
	map_remove_(i, a, "test".to_gtv()).run();
	assert_true(map_empty(i, a));
}

function test_map_clear() {
	val types = MapTypes(K = a_type.integer, V= a_type.text);
	Interface_("ITest", ["map": Type(Map(types))]).run();
	
	val m = [
		integer(42).to_gtv(): "test".to_gtv(),
		integer(21).to_gtv(): "test2".to_gtv(),
		integer(123).to_gtv(): "test3".to_gtv(),
		integer(321).to_gtv(): "test4".to_gtv(),
		integer(98).to_gtv(): "test5".to_gtv()
	];
	Instance_(["ITest"], ["map": Map(value=m)]).run();
	
	val i = get_last_instance();
	val a = get_attribute_by_dclass_name("ITest", "map");
	
	assert_true(map_contains_key(i, a, integer(123).to_gtv()));
	assert_equals(map_sizeof(i, a), 5);
	
	map_clear_(i, a).run();
	assert_true(map_empty(i, a));
	
	map_clear_(i, a).run();
	assert_true(map_empty(i, a));
	
	assert_false(map_contains_key(i, a, integer(123).to_gtv()));
}

function test_map_keys() {
	val types = MapTypes(K = a_type.integer, V= a_type.text);
	Interface_("ITest", ["map": Type(Map(types))]).run();
	
	val m = [
		integer(42).to_gtv(): "test".to_gtv(),
		integer(21).to_gtv(): "test2".to_gtv(),
		integer(123).to_gtv(): "test3".to_gtv(),
		integer(321).to_gtv(): "test4".to_gtv(),
		integer(98).to_gtv(): "test5".to_gtv()
	];
	Instance_(["ITest"], ["map": Map(value=m)]).run();
	
	val i = get_last_instance();
	val a = get_attribute_by_dclass_name("ITest", "map");
	
	val (t, r) = map_keys(i, a);
	assert_equals(t, a_type.integer);
	assert_equals(set([42,21,123,321,98]), set<integer>.from_gtv(r));
}

function test_map_values() {
	val types = MapTypes(K = a_type.integer, V= a_type.text);
	Interface_("ITest", ["map": Type(Map(types))]).run();
	
	val m = [
		integer(42).to_gtv(): "test".to_gtv(),
		integer(21).to_gtv(): "test2".to_gtv(),
		integer(123).to_gtv(): "test3".to_gtv(),
		integer(321).to_gtv(): "test4".to_gtv(),
		integer(98).to_gtv(): "test5".to_gtv()
	];
	Instance_(["ITest"], ["map": Map(value=m)]).run();
	
	val i = get_last_instance();
	val a = get_attribute_by_dclass_name("ITest", "map");
	
	val (t, r) = map_values(i, a);
	assert_equals(t, a_type.text);
	assert_equals(["test", "test2", "test3", "test4", "test5"], list<text>.from_gtv(r));
}

function test_map_keys_and_values_on_empty() {
	val types = MapTypes(K = a_type.integer, V= a_type.text);
	Interface_("ITest", ["map": Type(Map(types))]).run();
	
	Instance_(["ITest"], ["map": Map(value=map<gtv,gtv>())]).run();
	
	val i = get_last_instance();
	val a = get_attribute_by_dclass_name("ITest", "map");
	
	val (t1, r1) = map_values(i, a);
	assert_equals(t1, a_type.text);
	assert_equals(list<text>(), list<text>.from_gtv(r1));
	
	val (t2, r2) = map_keys(i, a);
	assert_equals(t2, a_type.integer);
	assert_equals(set<integer>(), set<integer>.from_gtv(r2));
}

function test_map_get() {
	var types = MapTypes(K = a_type.integer, V= a_type.text);
	Interface_("ITest", ["map": Type(Map(types))]).run();
	
	var m = [
		integer(42).to_gtv(): "test".to_gtv(),
		integer(21).to_gtv(): "test2".to_gtv()
	];
	Instance_(["ITest"], ["map": Map(value=m)]).run();
	
	var i = get_last_instance();
	var a = get_attribute_by_dclass_name("ITest", "map");
	
	assert_equals(text.from_gtv(map_get(i,a,integer(42).to_gtv())), "test");
	assert_equals(text.from_gtv(map_get(i,a,integer(21).to_gtv())), "test2");
	
	
	types = MapTypes(K = a_type.text, V= a_type.byte_array);
	Interface_("ITest2", ["map": Type(Map(types))]).run();
	
	m = [
		"test".to_gtv(): x"affe".to_gtv(),
		"test2".to_gtv(): x"caffee".to_gtv()
	];
	Instance_(["ITest2"], ["map": Map(value=m)]).run();
	
	i = get_last_instance();
	a = get_attribute_by_dclass_name("ITest2", "map");
	
	assert_equals(byte_array.from_gtv(map_get(i,a,"test".to_gtv())), x"affe");
	assert_equals(byte_array.from_gtv(map_get(i,a,"test2".to_gtv())), x"caffee");
}

function test_map_unpack() {
	val types = MapTypes(K = a_type.integer, V= a_type.text);
	Interface_("ITest", ["map": Type(Map(types))]).run();
	
	val m = [
		integer(42).to_gtv(): "test".to_gtv(),
		integer(21).to_gtv(): "test2".to_gtv(),
		integer(123).to_gtv(): "test3".to_gtv(),
		integer(321).to_gtv(): "test4".to_gtv(),
		integer(98).to_gtv(): "test5".to_gtv()
	];
	Instance_(["ITest"], ["map": Map(value=m)]).run();
	
	val i = get_last_instance();
	val a = get_attribute_by_dclass_name("ITest", "map");
	
	val (t, r) = map_unpack(i, a);
	
	assert_equals(t.K, a_type.integer);
	assert_equals(t.V, a_type.text);
	assert_equals(r, m);
}

function test_map_find_instances() {
	val types = MapTypes(K = a_type.text, V= a_type.integer);
	Interface_("ITest", ["map": Type(Map(types))]).run();
	
	val a = get_attribute_by_dclass_name("ITest", "map");	
	
	var m = [
		"test".to_gtv(): integer(21).to_gtv()
	];
	Instance_(["ITest"], ["map": Map(value=m)]).run();
	val i1 = get_last_instance();
	
	m = [
		"test".to_gtv(): integer(42).to_gtv(),
		"test2".to_gtv(): integer(21).to_gtv()
	];
	Instance_(["ITest"], ["map": Map(value=m)]).run();
	val i2 = get_last_instance();
	
	m = [
		"test".to_gtv(): integer(137).to_gtv(),
		"test2".to_gtv(): integer(21).to_gtv(),
		"test3".to_gtv(): integer(21).to_gtv()
	];
	Instance_(["ITest"], ["map": Map(value=m)]).run();
	val i3 = get_last_instance();
	
	val (r1, _) = find_instances_by_type_attribute(a, "test".to_gtv(), p_from(), integer.MAX_VALUE);
	assert_equals(set(r1), set([i1,i2,i3]));
	
	val (r2, _) = find_instances_by_type_attribute(a, "test2".to_gtv(), p_from(), integer.MAX_VALUE);
	assert_equals(set(r2), set([i2,i3]));
	
	val (r3, _) = find_instances_by_type_attribute(a, "test3".to_gtv(), p_from(), integer.MAX_VALUE);
	assert_equals(set(r3), set([i3]));
}
