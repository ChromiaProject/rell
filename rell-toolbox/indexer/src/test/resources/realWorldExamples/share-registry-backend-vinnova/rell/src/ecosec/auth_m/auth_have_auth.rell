	val expire_at = agent_m.cert_status @? {
		.cert.pubkey==agent_pubkey
	}(
		.expire_at
	) limit 1;
	print('>>>>>>>>>>>>>>>>>>expire_at ' + expire_at);

	print('>>>>>>>>>>>>>>>>>>agent_pubkey ' + agent_pubkey.to_hex());

	val real_pubkey = agent_m.cert_status @? {
		.cert.identity_nr=='19750912-1682'
	}(
		idenity_nr=.cert.identity_nr,
		pkey=.cert.pubkey
	) limit 1;
	if(real_pubkey!=null){
		print('>>>>>>>>>>>>>>>>>>real_pubkey ' + real_pubkey.pkey.to_hex());
	}*/

	return agent_m.cert_status @? {
		.cert.pubkey==agent_pubkey and
