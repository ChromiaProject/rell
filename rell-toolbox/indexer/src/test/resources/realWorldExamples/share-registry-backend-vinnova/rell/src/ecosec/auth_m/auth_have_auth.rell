	val validation_time_stamp = query_cert_worst_case_time();

	/*print('>>>>>>>>>>>>>>>>>>validation_time_stamp ' + validation_time_stamp);
	val valid_from = agent_m.cert_status @? {
		.cert.pubkey==agent_pubkey
	}(
		.valid_from
	) limit 1;
