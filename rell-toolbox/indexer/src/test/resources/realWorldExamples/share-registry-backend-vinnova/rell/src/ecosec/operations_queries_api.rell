// Blockchain initialization
/////////////////////////////////////////////////////////////////////

// Initiate reference tables and add founder
operation api_init (founder_pubkey: pubkey) {
	// This operation can only be run once (BC must be empty)

    init_m.init(founder_pubkey);
}

// Check if blockchain init data exists
query api_init_exists():(exists: boolean) {
	// Return Agent list
	return (exists=((agent_m.cert@*{} limit 1).size() != 0));
}

// Agent
/////////////////////////////////////////////////////////////////////

// Get agent id / record by pubkey (Used at initial authentication)
query api_agent_get_info(agent_pubkey: pubkey) {

	// TODO: Find a way to sign queries and check auth for agent_pubkey here

	val agent_id = auth_m.query_pubkey_get_active_cert_agent_id(agent_pubkey);

	require(agent_id != null, appmsg_m.msg('MSGE0105', 'agent', 'api_agent_get_info')); // No active cert

	// Check if agent have any BR role
	val is_br = ((pa: persona_m.persona_agent, pr: persona_m.persona_role) @? {
		pa.agent.id == agent_id!!,
		pr.role_type.id == persona_m.role_type_enum.BOARD_REP
	} limit 1) != null;

	// Return Agent record
	return agent_m.agent @ { .id == agent_id }(
		.id,
        //identity_type_id=.identity_type.id.value,
        //.identity_nr,
        .first_name,
        .last_name,
        .address1,
        .address2,
        .postal_code,
        .city,
        .country,
        .email,
        .phone,
        .administrator,
        .created_time_stamp,
        .changed_time_stamp,
        board_rep = is_br
	);
}

// Check if a specific agent_id exists (Only allowed for superadmin / founder, primarily used for testdata creation)
query api_agent_get_exists(agent_pubkey: pubkey, agent_id: text, check_agent_id: text):(exists: boolean) {

	// Check authorization, have cert
	// TODO: Find a way to sign queries and check auth for agent_id here
	// For now, check that Agent have active cert based on public key
	val active_cert =auth_m.query_get_active_cert(agent_pubkey, agent_id);
	require(active_cert != null, appmsg_m.msg('MSGE0105', 'agent', 'api_history_list_global')); // No active cert

	// Check authorization, Is admin
	require(auth_m.have_auth_admin(agent_id), appmsg_m.msg('MSGE0103', 'agent', 'api_blockchain_get_last_block_history')); // Not admin

	// Return Agent list
	return (exists=((agent_m.agent @* { .id == check_agent_id }).size() > 0));
}

// Get agent authorized personas with company information
query api_agent_get_authorized_personas(agent_pubkey: pubkey, agent_id: text){

	// Check authorization, have cert
	// TODO: Find a way to sign queries and check auth for agent_id here
	// For now, check that Agent have active cert based on public key
	val active_cert = auth_m.query_get_active_cert(agent_pubkey, agent_id);
	require(active_cert != null, appmsg_m.msg('MSGE0105', 'agent', 'api_agent_get_authorized_personas')); // No active cert

	// Get all personas and their companies
	return persona_m.persona_agent @* {.agent.id == agent_id} (
		persona_id= .persona.id,
		persona_first_name= .persona.first_name,
		persona_last_name= .persona.last_name,
		persona_address1= .persona.address1,
		persona_address2= .persona.address2,
		persona_postal_code= .persona.postal_code,
		persona_city= .persona.city,
		persona_country= .persona.country,
		persona_email= .persona.email,
		persona_phone= .persona.phone,
		persona_type= .persona.type.value,
		persona_created_time_stamp= .persona.created_time_stamp,
		persona_changed_time_stamp= .persona.changed_time_stamp,
		company_org_nr= .persona.company.org_nr,
		company_name= .persona.company.name,
		company_address1= .persona.company.address1,
		company_address2= .persona.company.address2,
		company_postal_code= .persona.company.postal_code,
		company_city= .persona.company.city,
		company_country= .persona.company.country,
		company_visit_address1= .persona.company.visit_address1,
		company_visit_address2= .persona.company.visit_address2,
		company_visit_postal_code= .persona.company.visit_postal_code,
		company_visit_city= .persona.company.visit_city,
		company_visit_country= .persona.company.visit_country,
		company_email= .persona.company.email,
		company_phone= .persona.company.phone
	);
}

// Get agent oldest group of requests where at least one is still pending, otherwise return empty array
//
// LIMITATIONS
//  - group of request found through same timestamp (of last block when req created)
//		which means that repeated UX requests for agent could have same timestamp
//		and this api return state of both these groups
query api_agent_get_oldest_request_group(agent_pubkey: pubkey, agent_id: text){

	// Check authorization, have cert
	// TODO: Find a way to sign queries and check auth for agent_id here
	// For now, check that Agent have active cert based on public key
	val active_cert = auth_m.query_get_active_cert(agent_pubkey, agent_id);
	require(active_cert != null, appmsg_m.msg('MSGE0105', 'agent', 'api_agent_get_oldest_request_group')); // No active cert

	// Get oldest pending request to get timestamp.
	val req = request_m.request_state @? { .request.agent.id == agent_id, .request_state_type.id == request_m.request_state_type_enum.PENDING }(
		request_id= .request.rowid,
		company_org_nr= .request.persona.company.org_nr,
		company_name= .request.persona.company.name,
		request_state_type_id= .request_state_type.id,
		@sort created_time_stamp= .request.created_time_stamp
	) limit 1;

    val tstamp = if( req == null)
        0
    else
        req.created_time_stamp;

	return request_m.request_state @* { .request.agent.id == agent_id, .request.created_time_stamp == tstamp }(
		request_id= .request.rowid,
		company_org_nr= .request.persona.company.org_nr,
		company_name= .request.persona.company.name,
		request_state_type_id= .request_state_type.id.value,
		request_state_type_name= .request_state_type.name,
		created_time_stamp= .request.created_time_stamp
	);
}

// Get list of all agents (only available to superadmin / founder)
query api_agent_list(agent_pubkey: pubkey, agent_id: text) {

	// Check authorization, have cert
	// TODO: Find a way to sign queries and check auth for agent_id here
	// For now, check that Agent have active cert based on public key
	val active_cert =auth_m.query_get_active_cert(agent_pubkey, agent_id);
	require(active_cert != null, appmsg_m.msg('MSGE0105', 'agent', 'api_history_list_global')); // No active cert

	// Check authorization, Is admin
	require(auth_m.have_auth_admin(agent_id), appmsg_m.msg('MSGE0103', 'agent', 'api_blockchain_get_last_block_history')); // Not admin

	// Return Agent list
	return agent_m.cert_status @* {  }(
		agent_id= .cert.agent.id,

		@sort last_name= .cert.agent.last_name,
		@sort first_name= .cert.agent.first_name,
        @sort identity_type_id= .cert.identity_type.id.value,
        @sort identity_nr= .cert.identity_nr,

        address1= .cert.agent.address1,
        address2= .cert.agent.address2,
        postal_code= .cert.agent.postal_code,
        city= .cert.agent.city,
        country= .cert.agent.country,

        phone= .cert.agent.phone,
        email= .cert.agent.email,

        administrator= .cert.agent.administrator,
        created_time_stamp= .cert.agent.created_time_stamp,
        changed_time_stamp= .cert.agent.changed_time_stamp,

        cert_status= .cert_status_type.id.value,
        cert_valid_from= .valid_from,
        cert_expire_at= .expire_at
	);
}

// Set target agent as system wide administrator
operation api_agent_set_admin(agent_pubkey: pubkey, agent_id: text, target_agent_id: text, target_agent_administrator: integer){

	agent_m.agent_set_admin(agent_pubkey, agent_id, target_agent_id, target_agent_administrator);
}

// Create request for address change (one request for each authroized persona is created)
operation api_agent_request_address_change(agent_pubkey: pubkey, agent_id: text, //agent_first_name: text, agent_last_name: text,
				agent_address1: text, agent_address2: text, agent_postal_code: text, agent_city: text, agent_country: text,
				agent_phone: text, agent_email: text) {

	agent_m.agent_request_address_change(agent_pubkey, agent_id, //agent_first_name, agent_last_name,
				agent_address1, agent_address2, agent_postal_code, agent_city, agent_country,
				agent_phone, agent_email);
}

// Get all pending requests for Bord representative (sorted by create time stamp)
query api_agent_br_get_pending_requests(agent_pubkey: pubkey, agent_id: text){

	// Check authorization, have cert
	// TODO: Find a way to sign queries and check auth for agent_id here
	// For now, check that Agent have active cert based on public key
	val active_cert =auth_m.query_get_active_cert(agent_pubkey, agent_id);
	require(active_cert != null, appmsg_m.msg('MSGE0105', 'agent', 'api_agent_br_get_pending_requests')); // No active cert

	// Get company pending requests (sort by name, persona_id, create time stamp)
	//return (persona p, persona x) @* { p.company.org_nr == '919191-9191' }(
	return (a_br: agent_m.agent, persona_m.persona_agent, p_br: persona_m.persona, persona_m.persona_role, c_br:company_m.company, p_rq: persona_m.persona , rq: request_m.request, request_m.request_state ) @* {
	        a_br.id ==  agent_id,           // Current BR agent
	        a_br == persona_agent.agent,    // Crossref all agent => personas
	        p_br == persona_agent.persona,  // Crossref all agent => personas
	        p_br == persona_role.persona,  // Crossref only persona role BR
	        persona_role.role_type == persona_m.role_type@{persona_m.role_type_enum.BOARD_REP},  // Crossref only persona role BR
	        p_br.company == c_br,           // Find all companies for br agent

	        c_br == p_rq.company,   // Find potential request personas from br companies
	        rq.persona == p_rq,     // Find requests for potential personas

	        request_state.request == rq, // Link to request state
	        request_state.request_state_type == request_m.request_state_type@{request_m.request_state_type_enum.PENDING} // Request state must be pending
	        }
	    (
		company_org_nr= c_br.org_nr,
		company_name= c_br.name,

	    persona_id= p_rq.id,
	    persona_first_name= p_rq.first_name,
	    persona_last_name= p_rq.last_name,
		persona_address1= p_rq.address1,
		persona_address2= p_rq.address2,
		persona_postal_code= p_rq.postal_code,
		persona_city= p_rq.city,
		persona_country= p_rq.country,
		persona_created_time_stamp= p_rq.created_time_stamp,
		persona_changed_time_stamp= p_rq.changed_time_stamp,
		request_id= rq.rowid,
		//request_first_name= rq.first_name,
		//request_last_name= rq.last_name,
		request_address1= rq.address1,
		request_address2= rq.address2,
		request_postal_code= rq.postal_code,
		request_city= rq.city,
		request_country= rq.country,
		request_phone= rq.phone,
		request_email= rq.email,
		@sort request_created_timestamp= rq.created_time_stamp
	);
}

// Company
/////////////////////////////////////////////////////////////////////

// List companies where agent have authorization
query api_company_list(agent_pubkey: pubkey, agent_id: text){

	// Check authorization, have cert
	// TODO: Find a way to sign queries and check auth for agent_id here
	// For now, check that Agent have active cert based on public key
	val active_cert = auth_m.query_get_active_cert(agent_pubkey, agent_id);
	require(active_cert != null, appmsg_m.msg('MSGE0105', 'Agent', 'api_company_list')); // No active cert

	// Authorization check, Is admin
	if(auth_m.have_auth_admin(agent_id)){
		return company_m.company @* {}(
			org_nr= .org_nr,
		    name= .name,

		    created_time_stamp= .created_time_stamp,
		    changed_time_stamp= .changed_time_stamp
		);
	}
	else { // Authorization check, Not admin

		// Use set to eliminate duplicates from personas with multiple roles, identity mappings
		// TODO: api_company_list, When "SQL grouping" is coming in Rell refactor?
		val c = set<(org_nr:text,name:text,created_time_stamp:timestamp,changed_time_stamp:timestamp)>();

		// Add all explicitly (cross-ref) mapped persona companies
		c.add_all((company_m.company, persona_m.persona, persona_m.persona_role, persona_m.role_type, persona_m.persona_agent, agent_m.agent) @* {
			persona.company == company, persona_role.persona == persona,
			persona_agent.persona == persona, persona_agent.agent == agent,
			agent.id == agent_id
		}(
			org_nr= company.org_nr,
		    name= company.name,

		    created_time_stamp= company.created_time_stamp,
		    changed_time_stamp= company.changed_time_stamp
		));

		// Add all agent auto identity mapped persona companies
		// TODO: api_company_list, See if auto identity mapping should instead be done by creating cross-ref when setting identity numbers
		// TODO: api_company_list, Find out if "SQL left / right joing" is coming in Rell (to possibly eliminate this separate select)
		c.add_all((company_m.company, persona_m.persona) @* {
			persona.company == company,
			//persona.identity_type == (cert @ { cert == active_cert!! } (identity_type=.identity_type.id)).identity_type,
			persona.identity_type == active_cert!!.identity_type, // Shorthand for line above
			persona.identity_nr == active_cert!!.identity_nr
		}(
			org_nr= company.org_nr,
		    name= company.name,

		    created_time_stamp= company.created_time_stamp,
		    changed_time_stamp= company.changed_time_stamp
		));

		return list<(org_nr:text,name:text,created_time_stamp:timestamp,changed_time_stamp:timestamp)>(c);
	}
}

// Get company record
query api_company_get(agent_pubkey: pubkey, agent_id: text, org_nr: text){

	// Check authorization, have cert
	// TODO: Find a way to sign queries and check auth for agent_id here
	// For now, check that Agent have active cert based on public key
	val active_cert = auth_m.query_get_active_cert(agent_pubkey, agent_id);
	require(active_cert != null, appmsg_m.msg('MSGE0105', 'Agent', 'api_company_get')); // No active cert

	// Check authorization, Is BR
	require(auth_m.have_auth_br(agent_id, org_nr), appmsg_m.msg('MSGE0102', 'board representative', 'company_set_br')); // Not board representative?

	return company_m.company @ {.org_nr == org_nr} (
	    org_nr= .org_nr,

	    name= .name,

	    address1= .address1,
	    address2= .address2,
	    postal_code= .postal_code,
	    city= .city,
		country= .country,
		visit_address1= .visit_address1,
		visit_address2= .visit_address2,
		visit_postal_code= .visit_postal_code,
		visit_city= .visit_city,
		visit_country= .visit_country,
		email= .email,
		phone= .phone,

		summons = .summons.value,

		share_count = .share_count,
		share_value = .share_value,

		clause_conversion = .clause_conversion,
    	clause_consent = .clause_consent,
    	clause_purchase_right = .clause_purchase_right,
    	clause_refusal = .clause_refusal,
    	clause_redemption = .clause_redemption,

	    created_time_stamp= .created_time_stamp,
	    changed_time_stamp= .changed_time_stamp
	);
}

