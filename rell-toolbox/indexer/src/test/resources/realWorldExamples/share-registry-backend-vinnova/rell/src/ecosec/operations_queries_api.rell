// Persona
/////////////////////////////////////////////////////////////////////

// Get all personas including share count for company
// - Filter to only return share holders
// - Also include role information
// - Sort by share count
query api_persona_list_with_share_count(agent_pubkey: pubkey, agent_id: text, org_nr: text){

	// Check authorization, have cert
	// TODO: Find a way to sign queries and check auth for agent_id here
	// For now, check that Agent have active cert based on public key
	val active_cert =auth_m.query_get_active_cert(agent_pubkey, agent_id);
	require(active_cert != null, appmsg_m.msg('MSGE0105', 'agent', 'api_persona_list')); // No active cert

	// Check authorization, Is BR
	require(auth_m.have_auth_br(agent_id, org_nr), appmsg_m.msg('MSGE0102', 'board representative', 'company_set_br')); // Not board representative?

	// Get the company's total share count
	val company_share_count =company_m.company @ { .org_nr == org_nr }( .share_count);

	// Get company personas (sort by role_id getting board rep on top)
	// TODO: api_persona_list, decide what information is allowed to show in the list
	// TODO: api_persona_list, If needed, optimize to single select each for roles and share count
	// TODO: api_persona_list, When Rell supports Group by / sum() this api can be further optimized
	// TODO: api_persona_list, If API sort option is required, both "list definition" and "persona_shares.add" need multiple paths with different field sequences

	// Create the list with the query return format
	val persona_return = list<(share_count: integer, last_name: text, first_name: text,
							identity_type_id: integer, identity_nr: text,
							persona_id: text, type: integer,
							company_share_count: integer,
							created_time_stamp: timestamp, changed_time_stamp: timestamp,
							roles: list<(id: integer, name: text)>
							)>();

	// Get the company Personas (missing role information and share count information)
	val p_list = persona_m.persona @* { .company.org_nr == org_nr };

	for( p in p_list ){
		val share_count = share_block_m.get_share_count_for_persona(p);

		if(share_count > 0){ // Only add persona if shares are owned
			val identity_type_id =p.identity_type.id; // TODO: api_persona_list_with_roles, Rell Bug gives error for directly using "p.identity_type.id.value"
			val persona_type = p.type; // TODO: api_persona_list_with_roles, Rell Bug gives error for directly using "p.type.value"

			// Add persona to return list
			persona_return.add( ( share_count = share_count,
				last_name = p.last_name, first_name = p.first_name,
				identity_type_id = identity_type_id.value, identity_nr = p.identity_nr,
				persona_id = p.id, type = persona_type.value,
				company_share_count = company_share_count,
				created_time_stamp = p.created_time_stamp, changed_time_stamp = p.changed_time_stamp,
				roles = persona_m.get_roles_for_persona(p)
			) );
		}
	}

	persona_return._sort();

	return persona_return;
}

// Get all personas including roles for company
// - Sort by last_name, first_name
query api_persona_list_with_roles(agent_pubkey: pubkey, agent_id: text, org_nr: text){

	// Check authorization, have cert
	// TODO: Find a way to sign queries and check auth for agent_id here
	// For now, check that Agent have active cert based on public key
	val active_cert =auth_m.query_get_active_cert(agent_pubkey, agent_id);
	require(active_cert != null, appmsg_m.msg('MSGE0105', 'agent', 'api_persona_list')); // No active cert

	// Check authorization, Is BR
	require(auth_m.have_auth_br(agent_id, org_nr), appmsg_m.msg('MSGE0102', 'board representative', 'company_set_br')); // Not board representative?

	// Get company personas (sort last_name, first_name)
	// TODO: api_persona_list, decide what information is allowed to show in the list
	// TODO: api_persona_list, If needed, optimize to single select each for roles
	// TODO: api_persona_list, When Rell supports Group by / sum() this api can be further optimized
	// TODO: api_persona_list, If API sort option is required, both "list definition" and "persona_list.add" need multiple paths with different field sequences

	// Create the list with the query return format
	val persona_return = list<(last_name: text, first_name: text,
							identity_type_id: integer, identity_nr: text,
							persona_id: text, type: integer,
							created_time_stamp: timestamp, changed_time_stamp: timestamp,
							roles: list<(id: integer, name: text)>
							)>();

	// Get the company Personas (missing role information )
	val p_list = persona_m.persona @* { .company.org_nr == org_nr };

	for( p in p_list ){
		val identity_type_id =p.identity_type.id; // TODO: api_persona_list_with_roles, Rell Bug gives error for directly using "p.identity_type.id.value"
		val persona_type = p.type; // TODO: api_persona_list_with_roles, Rell Bug gives error for directly using "p.type.value"

		persona_return.add( (last_name = p.last_name, first_name = p.first_name,
			identity_type_id = identity_type_id.value, identity_nr = p.identity_nr,
			persona_id = p.id, type = persona_type.value,
			created_time_stamp = p.created_time_stamp, changed_time_stamp = p.changed_time_stamp,
			roles = persona_m.get_roles_for_persona(p)
		) );
	}

	persona_return._sort();

	return persona_return;
}

