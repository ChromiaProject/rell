				old_persona_id: text, old_share_type: text,
				old_pledging: boolean, old_certificate: boolean,
				new_persona_id: text, new_share_type: text,
				new_pledging: boolean, new_certificate: boolean,
				new_parts: list<integer>)>
				){

	share_block_m.apply_change_list(agent_pubkey, agent_id,
				org_nr,
				old_share_count, old_share_value,
				new_share_count, new_share_value,
				change_list
				);
}

