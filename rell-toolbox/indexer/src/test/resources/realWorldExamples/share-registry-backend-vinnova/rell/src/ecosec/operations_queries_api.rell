// Get company warnings (Check company for inconsitencies)
query api_company_get_warnings(agent_pubkey: pubkey, agent_id: text,
				org_nr: text) {

	// Check authorization, have cert
	// TODO: Find a way to sign queries and check auth for agent_id here
	// For now, check that Agent have active cert based on public key
	val active_cert = auth_m.query_get_active_cert(agent_pubkey, agent_id);
	require(active_cert != null, appmsg_m.msg('MSGE0105', 'Agent', 'api_company_get_warnings')); // No active cert

	// Check authorization, Is BR
	require(auth_m.have_auth_br(agent_id, org_nr), appmsg_m.msg('MSGE0102', 'board representative', 'company_set_br')); // Not board representative?

	var no_shares = 0;
	var persona_no_role = 0;

	// No share block ?
	if((share_block_m.share_block @* { .company.org_nr == org_nr } limit 1).size() != 1 ){
		no_shares = 1;
	}

	// Any Persona without roles?
	for(p in persona_m.persona @* { .company.org_nr == org_nr }){
		if((persona_m.persona_role @* { .persona.company.org_nr == org_nr, .persona == p } limit 1).size() != 1){
			persona_no_role = 1;
		}
	}

	// TODO: api_company_get_warnings, Better way to be able to return any structure?
	var warnings = list<(no_shares: integer, persona_no_role: integer)>();
	warnings.add((no_shares = no_shares, persona_no_role = persona_no_role));
	return warnings[0];
}

// Get all pending requests for company (sorted  create time stamp)
query api_company_get_pending_requests(agent_pubkey: pubkey, agent_id: text, org_nr: text){

	// Check authorization, have cert
	// TODO: Find a way to sign queries and check auth for agent_id here
	// For now, check that Agent have active cert based on public key
	val active_cert =auth_m.query_get_active_cert(agent_pubkey, agent_id);
	require(active_cert != null, appmsg_m.msg('MSGE0105', 'agent', 'api_company_get_pending_requests')); // No active cert

	// Check authorization, Is BR
	require(auth_m.have_auth_br(agent_id, org_nr), appmsg_m.msg('MSGE0102', 'board representative', 'company_set_br')); // Not board representative?

	// Get company pending requests (sort by name, persona_id, create time stamp)
	return request_m.request_state @* { .request.persona.company.org_nr == org_nr, .request_state_type.id == request_m.request_state_type_enum.PENDING } (
		persona_id= .request.persona.id,
		persona_first_name= .request.persona.first_name,
		persona_last_name= .request.persona.last_name,
		persona_address1= .request.persona.address1,
		persona_address2= .request.persona.address2,
		persona_postal_code= .request.persona.postal_code,
		persona_city= .request.persona.city,
		persona_country= .request.persona.country,
		persona_created_time_stamp= .request.persona.created_time_stamp,
		persona_changed_time_stamp= .request.persona.changed_time_stamp,
		request_id= .request.rowid,
		//request_first_name= .request.first_name,
		//request_last_name= .request.last_name,
		request_address1= .request.address1,
		request_address2= .request.address2,
		request_postal_code= .request.postal_code,
		request_city= .request.city,
		request_country= .request.country,
		@sort request_created_timestamp= .request.created_time_stamp
	);
}

// Get pending requests for company persona (sorted by name create time stamp)
query api_company_get_persona_pending_requests(agent_pubkey: pubkey, agent_id: text, org_nr: text, persona_id: text ){

	// Check authorization, have cert
	// TODO: Find a way to sign queries and check auth for agent_id here
	// For now, check that Agent have active cert based on public key
	val active_cert =auth_m.query_get_active_cert(agent_pubkey, agent_id);
	require(active_cert != null, appmsg_m.msg('MSGE0105', 'agent', 'api_company_get_persona_pending_requests')); // No active cert

	// Check authorization, Is BR
	require(auth_m.have_auth_br(agent_id, org_nr), appmsg_m.msg('MSGE0102', 'board representative', 'company_set_br')); // Not board representative?

	// Get persona pending requests (sort by  create time stamp)
	return request_m.request_state @* { .request.persona.id == persona_id, .request_state_type.id == request_m.request_state_type_enum.PENDING } (
		persona_id= .request.persona.id,
		persona_first_name= .request.persona.first_name,
		persona_last_name= .request.persona.last_name,
		persona_address1= .request.persona.address1,
		persona_address2= .request.persona.address2,
		persona_postal_code= .request.persona.postal_code,
		persona_city= .request.persona.city,
		persona_country= .request.persona.country,
		persona_created_time_stamp= .request.persona.created_time_stamp,
		persona_changed_time_stamp= .request.persona.changed_time_stamp,
		request_id= .request.rowid,
		//request_first_name= .request.first_name,
		//request_last_name= .request.last_name,
		request_address1= .request.address1,
		request_address2= .request.address2,
		request_postal_code= .request.postal_code,
		request_city= .request.city,
		request_country= .request.country,
		request_phone= .request.phone,
		request_email= .request.email,
		@sort request_created_timestamp= .request.created_time_stamp
	);
}

