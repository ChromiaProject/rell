// Get Persona info
// - Agent must be authorized for Persona or be a BR
query api_persona_get(agent_pubkey: pubkey, agent_id: text, org_nr: text, persona_id: text){

	// Check authorization, have cert
	// TODO: Find a way to sign queries and check auth for agent_id here
	// For now, check that Agent have active cert based on public key
	val active_cert =auth_m.query_get_active_cert(agent_pubkey, agent_id);
	require(active_cert != null, appmsg_m.msg('MSGE0105', 'agent', 'api_persona_get')); // No active cert

	// Check authorization, Is BR or agent authorized for persona
	val have_auth_for_persona = (persona_m.persona_agent @? { .agent.id == agent_id, .persona.id == persona_id}) != null;
	if((persona_m.persona_agent @? { .agent.id == agent_id, .persona.id == persona_id}) == null){ // If agent is not authorized for persona
		require(auth_m.have_auth_br(agent_id, org_nr), appmsg_m.msg('MSGE0102', 'board representative', 'company_set_br')); // Not board representative?
	}

    // Get Persona
    val p = persona_m.persona @ { .id == persona_id };

    val identity_type_id =p.identity_type.id; // TODO: api_persona_get, Rell Bug gives error for directly using "p.identity_type.id.value"
    val persona_type_id =p.type; // TODO: api_persona_get, Rell Bug gives error for directly using "p.type.value"

	// Return persona including roles list
	return (id=p.id, first_name=p.first_name, last_name=p.last_name, address1=p.address1, address2=p.address2, postal_code=p.postal_code, city=p.city, country=p.country,
		phone=p.phone, email=p.email, type=persona_type_id.value, identity_type_id=identity_type_id.value, identity_nr=p.identity_nr, trustee=p.trustee,
		created_time_stamp=p.created_time_stamp, changed_time_stamp=p.changed_time_stamp,
		roles=persona_m.get_roles_for_persona(p)
	);
}

// Share blocks
/////////////////////////////////////////////////////////////////////

// Get all share blocks for company
query api_share_block_list(agent_pubkey: pubkey, agent_id: text, org_nr: text){

	// Check authorization, have cert
	// TODO: Find a way to sign queries and check auth for agent_id here
	// For now, check that Agent have active cert based on public key
	val active_cert =auth_m.query_get_active_cert(agent_pubkey, agent_id);
	require(active_cert != null, appmsg_m.msg('MSGE0105', 'agent', 'api_share_block_list')); // No active cert

	// Check authorization, Is BR
	require(auth_m.have_auth_br(agent_id, org_nr), appmsg_m.msg('MSGE0102', 'board representative', 'company_set_br')); // Not board representative?

	// Get the company's total share count
	val (company_share_count,company_share_value) = company_m.company @ { .org_nr == org_nr }( .share_count, .share_value);

	val sb_list = (sb: share_block_m.share_block, sbp: share_block_m.share_block_persona) @* {
				sbp.share_block == sb,
				sb.company.org_nr == org_nr
			}(
				@sort org_nr = sb.company.org_nr,
				@sort share_from = sb.share_from,
				@sort share_to = sb.share_to,

				persona_id = sbp.persona.id,
				persona_first_name = sbp.persona.first_name,
				persona_last_name = sbp.persona.last_name,
				persona_identity_type = sbp.persona.identity_type,
				persona_identity_nr = sbp.persona.identity_nr,

				share_type = sb.share_type,
				certificate = sb.certificate,
				pledging = sb.pledging,
				recalled = sb.recalled,

				created_time_stamp= sb.created_time_stamp,
		    	changed_time_stamp= sb.changed_time_stamp
			);

	return (share_block = sb_list,
		company_share_count = company_share_count,
		company_share_value = company_share_value
		);
}

// Get list of share blocks for persona including own/company share count
// - Requires agent is authorized for persona or agent is BR
query api_share_block_list_for_persona(agent_pubkey: pubkey, agent_id: text, org_nr: text, persona_id: text){

	// Check authorization, have cert
	// TODO: Find a way to sign queries and check auth for agent_id here
	// For now, check that Agent have active cert based on public key
	val active_cert =auth_m.query_get_active_cert(agent_pubkey, agent_id);
	require(active_cert != null, appmsg_m.msg('MSGE0105', 'agent', 'api_persona_get')); // No active cert

	// Check authorization, Is BR or agent authorized for persona
	val have_auth_for_persona = (persona_m.persona_agent @? { .agent.id == agent_id, .persona.id == persona_id}) != null;
	if((persona_m.persona_agent @? { .agent.id == agent_id, .persona.id == persona_id}) == null){ // If agent is not authorized for persona
		require(auth_m.have_auth_br(agent_id, org_nr), appmsg_m.msg('MSGE0102', 'board representative', 'company_set_br')); // Not board representative?
	}

	// Get the company's total share count
	val (company_share_count,company_share_value) = company_m.company @ { .org_nr == org_nr }( .share_count, .share_value);

	// Get Persona share blocks
	val sb_list = (sb: share_block_m.share_block, sbp: share_block_m.share_block_persona) @* {
				sbp.share_block == sb,
				sb.company.org_nr == org_nr,
				sbp.persona.id == persona_id
			}(
				@sort org_nr = sb.company.org_nr,
				@sort share_from = sb.share_from,
				@sort share_to = sb.share_to,

				persona_id = sbp.persona.id,
				persona_first_name = sbp.persona.first_name,
				persona_last_name = sbp.persona.last_name,
				persona_identity_type = sbp.persona.identity_type,
				persona_identity_nr = sbp.persona.identity_nr,

				share_type = sb.share_type,
				certificate = sb.certificate,
				pledging = sb.pledging,
				recalled = sb.recalled,

				created_time_stamp= sb.created_time_stamp,
		    	changed_time_stamp= sb.changed_time_stamp
			);

	// Persona share count
	var persona_share_count = 0;
	for(sb in sb_list){
		persona_share_count += sb.share_to - sb.share_from + 1;
	}

	return (share_block = sb_list,
			share_count = persona_share_count,
			company_share_count = company_share_count,
			company_share_value = company_share_value
			);
}

operation api_share_block_apply_change_list(agent_pubkey: pubkey, agent_id: text,
				org_nr: text,
				old_share_count: integer, old_share_value: integer,
