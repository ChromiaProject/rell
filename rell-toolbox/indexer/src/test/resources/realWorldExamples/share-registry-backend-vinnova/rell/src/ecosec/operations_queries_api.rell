// History Log
/////////////////////////////////////////////////////////////////////

// List history for one company
query api_history_list_company(agent_pubkey: pubkey, agent_id: text, org_nr: text, from_time_stamp: timestamp){

	// Check authorization, have cert
	// TODO: Find a way to sign queries and check auth for agent_id here
	// For now, check that Agent have active cert based on public key
	val active_cert =auth_m.query_get_active_cert(agent_pubkey, agent_id);
	require(active_cert != null, appmsg_m.msg('MSGE0105', 'agent', 'api_history_list_company')); // No active cert

	// Check authorization, Is BR
	require(auth_m.have_auth_br(agent_id, org_nr), appmsg_m.msg('MSGE0102', 'board representative', 'company_set_br')); // Not board representative?

	return (h: history_m.history) @* { .company_org_nr == org_nr, .created_time_stamp >= from_time_stamp}(
		@sort .company_org_nr,
		@sort .created_time_stamp,
		@sort .rowid, // TODO: api_history_list_global, Index with rowid at end currently not possible,

		// Agent acting in the solution
		.agent_id,
		//.agent_pubkey, // Should not be sent to front-end if not required (at least until system is secured)
		.agent_first_name,
		.agent_last_name,
		.agent_identity_type_id,
		.agent_identity_nr,

		// Changes
		.object_type_id,
		.object_type_text,
		.event_type_id,
		.event_type_text,
		.old,
		.new,

		// Allow search based on affected object
		.object_id,
		.object_text,

		// Allow search based on affected persona
		.persona_id,
		.persona_first_name,
		.persona_last_name,
		.persona_identity_type_id,
		.persona_identity_nr,

		// Allow mapping to blockchain block
		.block_height,

		// Blockchain version at the time of the record
		.major_version,
		.minor_version
	);
}

// List history for system (non company specific) (This logging is not yet implemented!)
query api_history_list_system(agent_pubkey: pubkey, agent_id: text, from_time_stamp: timestamp){

	// Check authorization, have cert
	// TODO: Find a way to sign queries and check auth for agent_id here
	// For now, check that Agent have active cert based on public key
	val active_cert =auth_m.query_get_active_cert(agent_pubkey, agent_id);
	require(active_cert != null, appmsg_m.msg('MSGE0105', 'agent', 'api_history_list_system')); // No active cert

	// Check authorization, Is admin
	require(auth_m.have_auth_admin(agent_id), appmsg_m.msg('MSGE0103', 'agent', 'api_blockchain_get_last_block_history')); // Not admin

	return (h: history_m.history) @* { .company_org_nr == '000000-0000', .created_time_stamp >= from_time_stamp}(
		@sort .company_org_nr,
		@sort .created_time_stamp,
		@sort .rowid, // TODO: api_history_list_global, Index with rowid at end currently not possible

		// Agent acting in the solution
		.agent_id,
		//.agent_pubkey, // Should not be sent to front-end if not required (at least until system is secured)
		.agent_first_name,
		.agent_last_name,
		.agent_identity_type_id,
		.agent_identity_nr,

		// Changes
		.object_type_id,
		.object_type_text,
		.event_type_id,
		.event_type_text,
		.old,
		.new,

		// Allow search based on affected object
		.object_id,
		.object_text,

		// Allow search based on affected persona
		.persona_id,
		.persona_first_name,
		.persona_last_name,
		.persona_identity_type_id,
		.persona_identity_nr,

		// Allow mapping to blockchain block
		.block_height,

		// Blockchain version at the time of the record
		.major_version,
		.minor_version
	);
}

// List global history, ie for system and all companies
query api_history_list_global(agent_pubkey: pubkey, agent_id: text, from_time_stamp: timestamp){

	// Check authorization, have cert
	// TODO: Find a way to sign queries and check auth for agent_id here
	// For now, check that Agent have active cert based on public key
	val active_cert =auth_m.query_get_active_cert(agent_pubkey, agent_id);
	require(active_cert != null, appmsg_m.msg('MSGE0105', 'agent', 'api_history_list_global')); // No active cert

	// Check authorization, Is admin
	require(auth_m.have_auth_admin(agent_id), appmsg_m.msg('MSGE0103', 'agent', 'api_blockchain_get_last_block_history')); // Not admin

		return (h: history_m.history) @* { .created_time_stamp >= from_time_stamp}(
			.company_org_nr,
			@sort .created_time_stamp,
			@sort .rowid, // TODO: api_history_list_global, Index with rowid at end currently not possible

			// Agent acting in the solution
			.agent_id,
			//.agent_pubkey, // Should not be sent to front-end if not required (at least until system is secured)
			.agent_first_name,
			.agent_last_name,
			.agent_identity_type_id,
			.agent_identity_nr,

			// Changes
			.object_type_id,
			.object_type_text,
			.event_type_id,
			.event_type_text,
			.old,
			.new,

			// Allow search based on affected object
			.object_id,
			.object_text,

			// Allow search based on affected persona
			.persona_id,
			.persona_first_name,
			.persona_last_name,
			.persona_identity_type_id,
			.persona_identity_nr,

			// Allow mapping to blockchain block
			.block_height,

			// Blockchain version at the time of the record
			.major_version,
			.minor_version
		);
}


// Blockhain - Mini explorer
/////////////////////////////////////////////////////////////////////

// Get the last "count" blocks with block_height and timestamp
query api_blockchain_get_last_block(count: integer){
	return block @* {} (
		@sort_desc .block_height,
		.block_rid,
		.timestamp
	) limit count;
}

// Get the last "count" blocks with history
//
// LIMITATIONS
// - Only blocks with history records are listed
query api_blockchain_get_last_block_history(agent_pubkey: pubkey, agent_id: text, count: integer){

	// Check authorization, have cert
	// TODO: Find a way to sign queries and check auth for agent_id here
	// For now, check that Agent have active cert based on public key
	val active_cert =auth_m.query_get_active_cert(agent_pubkey, agent_id);
	require(active_cert != null, appmsg_m.msg('MSGE0105', 'agent', 'api_blockchain_get_last_block_history')); // No active cert

	// Check authorization, Is admin
	require(auth_m.have_auth_admin(agent_id), appmsg_m.msg('MSGE0103', 'agent', 'api_blockchain_get_last_block_history')); // Not admin

	// TODO: api_blockchain_get_last_block_history, When "left join" exist in Rell, adopt to always list every block even if no history records
	val block_height = block @ {}( @sort_desc .block_height ) limit 1;

	return (b: block, h: history_m.history) @* { b.block_height > block_height - count } (
		@sort block_height = b.block_height,
		timestamp = b.timestamp,
		block_rid = b.block_rid,
		@sort rowid = h.rowid,
		org_nr = h.company_org_nr,
		object_type_id = h.object_type_id,
		object_type_text = h.object_type_text,
		event_type_id = h.event_type_id,
		event_type_text = h.event_type_text,
		object_id = h.object_id,
		object_text = h.object_text
	);
}

// DemoAuth - emulated sign up / sign in
/////////////////////////////////////////////////////////////////////

// Demo emulated Signup for agent
operation api_demoauth_sign_up(new_agent_pubkey: pubkey, new_agent_id: text,
			identity_nr: text,
			first_name: text,
			last_name: text,
			address1: text,
			address2: text,
			postal_code: text,
			city: text,
			country: text,
			phone: text,
			email: text
		){

	demoauth_m.sign_up(new_agent_pubkey, new_agent_id,
			identity_nr,
			first_name,
			last_name,
			address1,
			address2,
			postal_code,
			city,
			country,
			phone,
			email
		);
}
