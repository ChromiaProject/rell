function test_unable_to_purchase_alice_seed_via_unknown_chain() {
	val alice = finalize_seed_user(ft3_test.create_ft3_test_acc(util.alice_keypair()));
		
	val tx1 = rell.test.tx()
		.op(minter.mint_alice_seed(alice.address, "BTC", "1"))
		.sign(util.admin_keypair());
		
	rell.test.block().tx(tx1).run_must_fail();
}

