
//****************************************
// query_cert_worst_case_time
//
// - Return the "current worst case time" from a
//   certificate validity perspective based on the
//   time of the latest existing block.
// - "Slower" query version of cert_worst_case_time
//   where op_context is not available
//
// LIMITATIONS
// -

function query_cert_worst_case_time(): timestamp{
	val last_block = block @ {}( @sort_desc .block_height, .timestamp ) limit 1;

	return last_block.timestamp + 1000*60*60*24; // Last block time + 24h
}