    "files" : {
      "main.rell" : "entity user { name: text; mutable score: integer; }\nquery q() {\n            val n = 33;\n            val us = user @* {} ( user, .name, .score );\n            if (us.size() != n) return 'size:' + us.size();\n            for (i in range(n)) {\n                val exp = i * i + 100;\n                val u = us[i];\n                if (u.score != exp) return 'score:' + u;\n            }\n            return 'OK';\n        }"
