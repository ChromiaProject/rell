module;

query typedQuery(arg1: integer, arg2: text): text {
    val val1 = 1;
    val val2 = "val2";
    return val2;
}

//Sets arguments on new line when query definition is above maxLineWidth (120 standard)
// query maxLineWidthQuery(arg1: integer,arg2: text,arg3: text,arg4: integer,extraLongArgument1: text,extraLongArgument2: text ): text {
query maxLineWidthQuery(
    arg1: integer,
    arg2: text,
    arg3: text,
    arg4: integer,
    extraLongArgument1: text,
    extraLongArgument2: text
): text {
    val val1 = 1;
    val val2 = "val2";
    return val2;
}

//Arguments of query remains on new line if they are defined by the user with line seperator
//even though line width is smaller than max line width
query multiLineUserDefinedQuery(
    arg1: integer,
    arg2: text
): text {
    val val1 = 1;
    val val2 = "val2";
    return val2;
}

query multiLineUserDefinedSingleArg(
    arg1: integer
): text {
    return "foo";
}

query defaultQuery() {
    val val1 = 1;
    val val2 = "val2";
    return val2;
}
