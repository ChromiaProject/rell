module;
import submodule.*;
import somealias: ^.submodule;

@extendable function some_extendable(amount: integer);

function other_addition(paramA: integer, paramB: integer): integer {
    require(paramA > 0);
    val localA = paramA;
    val localB = paramB;

    val localC = localA + paramA;

    return localC;
}

