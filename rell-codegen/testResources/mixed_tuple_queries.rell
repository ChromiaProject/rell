module;

query return_type_unnamed_tuple() = (12, 42);
query return_type_named_tuple() = (bar=12, foo=42);
query return_type_unnamed_and_named_tuple() = (12, foo=42);
query return_type_nullable_unnamed_and_named_tuple(): (integer, foo:integer)? = (12, foo=42);
query return_type_list_unnamed_and_named_tuple(): list<(integer, foo:integer)> = [(12, foo=42)];
query return_type_map_unnamed_and_named_tuple() = ["foo": (12, foo=42)];
