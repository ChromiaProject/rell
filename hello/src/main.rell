module;

object my_name {
  mutable name= "World";
 }

enum my_enum{
    A, B
}

struct my_struct {
    name;
}

entity simple {}

entity my_entity {
    key name;
    index my_index: integer;
    simple;
}

operation set_name(name) {
  my_name.name = name;
}

query hello_world() = "Hello %s!".format(my_name.name);
