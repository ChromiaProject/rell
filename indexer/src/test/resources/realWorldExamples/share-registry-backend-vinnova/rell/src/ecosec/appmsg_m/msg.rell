function msg(code: text, arg1: text, arg2: text): text {
	// code : Unique message code mapping to a text
	// arg1 : Context info. Recommended: object (class / type / role / etc)
	// arg2 : Context info. Recommended: function/operation/query name 

	val msg = 'APPMESSAGE:{ code: "' + code + '", text: "' + apptext(code) + '", arg1: "' + arg1 + '", arg2: "' + arg2 + '"}';
	
	print(msg);
	
	return msg;
}