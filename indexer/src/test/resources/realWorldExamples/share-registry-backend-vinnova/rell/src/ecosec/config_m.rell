module;
//****************************************
// settings - record
//
// - Used for global settings that are
//   blockchain code version dependent.

// Settings for running code version
struct settings {
	major_version: integer = 0;
	minor_version: integer = 1;
}

// Settings in DB (Should be pushed
object db_settings {
	major_version: integer = 0;
	minor_version: integer = 1;
}

