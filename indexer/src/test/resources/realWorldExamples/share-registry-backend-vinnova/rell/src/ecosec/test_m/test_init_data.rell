	);
	
	// Agents with cert and persona
	val tmp_agent1 = create agent_m.agent (  // Agent
		id = agent1_id,
		//identity_type_id = 0,
		//identity_nr = "111111-1111",
		first_name = "Karl",
		last_name = "Own",
