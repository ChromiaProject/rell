	);
	val agent1_cert = create agent_m.cert ( // Cert
		tmp_agent1,
	    identity_type = identity_m.id_type @ {identity_m.id_type_enum.SWE_ID},
	    identity_nr = "111111-1111",
	    pubkey=a1_pubkey,
	    signer_pubkey=f_pubkey
	); 
	create agent_m.cert_status ( // Cert Status (active)
		agent1_cert,
		agent_m.cert_status_type@{agent_m.cert_status_type_enum.ACTIVE},
		valid_from = op_context.last_block_time,
		expire_at = integer.MAX_VALUE
	); 
	create persona_m.persona_agent ( // Agent represents persona
		persona_m.persona@{.id == persona1_id},
		tmp_agent1
	);
	create persona_m.persona_agent ( // Agent represents persona
