function test_admin_should_be_able_to_update_ethereum_sync_block() {
	val tx1 = rell.test
		.tx()
		.op(minter.update_block_height("Ethereum", 10))
		.sign(util.admin_keypair());
		
	rell.test
		.block()
		.tx(init())
		.tx(tx1)
		.run();
		
	val height = minter.sync_status @ { "Ethereum" } ( .block_height );
	
	assert_equals(height, 10);
}

