
function _get_id_property(props: map<name, prop>): name? {
	var id_property_names = list<name>();
	
	for ((name, prop) in props) {
		if (prop.prop_type_struct.type == property_type.id) {
			id_property_names.add(name);
		}
	}
	
	require(
		id_property_names.size() <= 1, 
		"Found " + id_property_names.size() + " properties of type ID"
	);
	
	return if (id_property_names.size() == 1) id_property_names[0] else null; 
}

function _get_owner_property(props: map<name, prop>): name? {
	var owner_property_names = list<name>();
	
	for ((name, prop) in props) {
		if (prop.prop_type_struct.type == property_type.account) {
			val account_type = account.from_gtv(prop.prop_type_struct.type_gtv);
			if (account_type.owner.value) {
				owner_property_names.add(name);
			}
		}
	}
	
	require(
		owner_property_names.size() <= 1,
		"Only one FT3 account property can be owner, but found " + owner_property_names.size()	
	);
	
	return if (owner_property_names.size() == 1) owner_property_names[0] else null;
}