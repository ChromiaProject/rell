function init(): rell.test.tx {
	val admin = ft3_test.create_ft3_test_acc(util.admin_keypair());
	
	return rell.test
		.tx()
		.op(mysterious_seed.initialize())
		.op(minter.initialize())
		.op(marketplace_ops.def_original("Starberry Seed", ["Seed"], list<marketplace.property_def>(), get_base_props("Starberry Seed"), admin.id, admin.auth_descriptor))
		.op(marketplace_ops.def_original("Leafy Plum Seed", ["Seed"], list<marketplace.property_def>(), get_base_props("Leafy Plum Seed"), admin.id, admin.auth_descriptor))
		.op(marketplace_ops.def_original("Rooster Fruit Seed", ["Seed"], list<marketplace.property_def>(), get_base_props("Rooster Fruit Seed"), admin.id, admin.auth_descriptor))
		.op(marketplace_ops.def_original("Dragon Brut Seed", ["Seed"], list<marketplace.property_def>(), get_base_props("Dragon Brut Seed"), admin.id, admin.auth_descriptor))
		.op(marketplace_ops.def_original("Blue Velvet Seed", ["Seed"], list<marketplace.property_def>(), get_base_props("Blue Velvet Seed"), admin.id, admin.auth_descriptor))
		.op(marketplace_ops.def_original("Moondrop Seed", ["Seed"], list<marketplace.property_def>(), get_base_props("Moondrop Seed"), admin.id, admin.auth_descriptor))
		.op(marketplace_ops.def_original("Sapphire Lettuce Seed", ["Seed"], list<marketplace.property_def>(), get_base_props("Sapphire Lettuce Seed"), admin.id, admin.auth_descriptor))
		.op(marketplace_ops.def_original("Peppery Onion Seed", ["Seed"], list<marketplace.property_def>(), get_base_props("Peppery Onion Seed"), admin.id, admin.auth_descriptor))
		.op(marketplace_ops.def_original("Starberry", ["Fruit"], list<marketplace.property_def>(), get_base_props("Starberry"), admin.id, admin.auth_descriptor))
		.op(marketplace_ops.def_original("Leafy Plum", ["Fruit"], list<marketplace.property_def>(), get_base_props("Leafy Plum"), admin.id, admin.auth_descriptor))
		.op(marketplace_ops.def_original("Rooster Fruit", ["Fruit"], list<marketplace.property_def>(), get_base_props("Rooster Fruit"), admin.id, admin.auth_descriptor))
		.op(marketplace_ops.def_original("Dragon Brut", ["Fruit"], list<marketplace.property_def>(), get_base_props("Dragon Brut"), admin.id, admin.auth_descriptor))
		.op(marketplace_ops.def_original("Blue Velvet", ["Fruit"], list<marketplace.property_def>(), get_base_props("Blue Velvet"), admin.id, admin.auth_descriptor))
		.op(marketplace_ops.def_original("Moondrop", ["Fruit"], list<marketplace.property_def>(), get_base_props("Moondrop"), admin.id, admin.auth_descriptor))
		.op(marketplace_ops.def_original("Sapphire Lettuce", ["Fruit"], list<marketplace.property_def>(), get_base_props("Sapphire Lettuce"), admin.id, admin.auth_descriptor))
		.op(marketplace_ops.def_original("Peppery Onion", ["Fruit"], list<marketplace.property_def>(), get_base_props("Peppery Onion"), admin.id, admin.auth_descriptor))
		.sign(util.admin_keypair());
}

function get_base_props(name) {
	return [ 
		create_text_prop("name", name),
		create_text_prop("designer_name", "UberArtist"),
		create_text_prop("description", "Some description..."),
		create_image_prop("image")
	];
}

function create_text_prop(name, text): marketplace.property {
	return marketplace.property(
		name = name, 
		value = text.to_gtv()
	);
}

function create_image_prop(name): marketplace.property {
	val values = map<name, text>();
	values.put("type", "svg+xml");
	values.put("data", "");
	
	return marketplace.property(
		name = name,
		value = values.to_gtv()
	);
}