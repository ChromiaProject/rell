function test_days_planted_does_not_increment_after_death() {
	val alice = finalize_seed_user(ft3_test.create_ft3_test_acc(util.alice_keypair()));
		
	val tx1 = rell.test
		.tx()
		.op(minter.mint_alice_seed(alice.address, "Ethereum", "1"))
		.sign(util.admin_keypair());
		
	rell.test
		.block()
		.tx(init())
		.tx(tx1)
		.run();
		
	val originals = get_originals_for_account(alice.account.id);
	var original_id = byte_array.from_gtv(originals[0].get("id")!!);
		
	val tx2 = rell.test
		.tx()
		.op(mysterious_seed.plant_seed(alice.account.id, alice.auth_descriptor, original_id))
		.sign(alice.keypair);
		
	rell.test
		.block()
		.tx(tx2)
		.run();
			
	val status = mysterious_seed.retrieve_plant_status(alice.account, time.days_from_now(6));
	assert_equals(status.days_planted, 0);
	assert_equals(status.status, "dead");
}

function test_completing_tasks_makes_it_healthy() {
	val alice = finalize_seed_user(ft3_test.create_ft3_test_acc(util.alice_keypair()));
		
	val tx1 = rell.test
		.tx()
		.op(minter.mint_alice_seed(alice.address, "Ethereum", "1"))
		.sign(util.admin_keypair());
		
	rell.test
		.block()
		.tx(init())
		.tx(tx1)
		.run();
		
	val originals = get_originals_for_account(alice.account.id);
	var original_id = byte_array.from_gtv(originals[0].get("id")!!);
		
	val tx2 = rell.test
		.tx()
		.op(mysterious_seed.plant_seed(alice.account.id, alice.auth_descriptor, original_id))
		.op(mysterious_seed.water_plant(alice.account.id, alice.auth_descriptor, 1))
		.op(mysterious_seed.entertain_plant(alice.account.id, alice.auth_descriptor, 1))
		.sign(alice.keypair);
		
	rell.test
		.block()
		.tx(tx2)
		.run();
			
	val status = mysterious_seed.retrieve_plant_status(alice.account, time.now());
	assert_equals(status.status, "healthy");
}

function test_completing_all_tasks_makes_the_plant_healthy() {
	val alice = finalize_seed_user(ft3_test.create_ft3_test_acc(util.alice_keypair()));
		
	val tx1 = rell.test
		.tx()
		.op(minter.mint_alice_seed(alice.address, "Ethereum", "1"))
		.sign(util.admin_keypair());
		
	rell.test
		.block()
		.tx(init())
		.tx(tx1)
		.run();
		
	val originals = get_originals_for_account(alice.account.id);
	var original_id = byte_array.from_gtv(originals[0].get("id")!!);
		
	val tx2 = rell.test
		.tx()
		.op(mysterious_seed.plant_seed(alice.account.id, alice.auth_descriptor, original_id))
		.op(mysterious_seed.water_plant(alice.account.id, alice.auth_descriptor, 1))
		.op(mysterious_seed.fertilize_plant(alice.account.id, alice.auth_descriptor, 1))
		.op(mysterious_seed.entertain_plant(alice.account.id, alice.auth_descriptor, 1))
		.sign(alice.keypair);
		
	rell.test
		.block()
		.tx(tx2)
		.run();
			
	val status = mysterious_seed.retrieve_plant_status(alice.account, time.now());
	assert_equals(status.status, "healthy");
}

function test_plant_should_be_1_day_planted_after_completing_first_bonus() {
	val alice = finalize_seed_user(ft3_test.create_ft3_test_acc(util.alice_keypair()));
		
	val tx1 = rell.test
		.tx()
		.op(minter.mint_alice_seed(alice.address, "Ethereum", "1"))
		.sign(util.admin_keypair());
		
	rell.test
		.block()
		.tx(init())
		.tx(tx1)
		.run();
		
	val originals = get_originals_for_account(alice.account.id);
	var original_id = byte_array.from_gtv(originals[0].get("id")!!);
		
	val tx2 = rell.test
		.tx()
		.op(mysterious_seed.plant_seed(alice.account.id, alice.auth_descriptor, original_id))
		.op(mysterious_seed.fertilize_plant(alice.account.id, alice.auth_descriptor, 10))
		.sign(alice.keypair);
		
	rell.test
		.block()
		.tx(tx2)
		.run();
			
	val status = mysterious_seed.retrieve_plant_status(alice.account, time.now());
	
	assert_equals(status.days_planted, 1);
}