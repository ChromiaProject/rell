function test_plant_is_dying_after_12h() {
  val alice = finalize_seed_user(ft3_test.create_ft3_test_acc(util.alice_keypair()));
    
  val tx1 = rell.test
    .tx()
    .op(minter.mint_alice_seed(alice.address, "Ethereum", "1"))
    .sign(util.admin_keypair());
    
  rell.test
    .block()
    .tx(init())
    .tx(tx1)
    .run();
    
  val originals = get_originals_for_account(alice.account.id);
  var original_id = byte_array.from_gtv(originals[0].get("id")!!);
      
  val tx2 = rell.test
    .tx()
    .op(mysterious_seed.plant_seed(alice.account.id, alice.auth_descriptor, original_id))
    .sign(alice.keypair);
    
  rell.test
    .block()
    .tx(tx2)
    .run();
      
  val status = mysterious_seed.retrieve_plant_status(alice.account, time.hours_from_now(12) + 1000);
  
  assert_equals(status.status, "dying");
}

function test_plant_remains_dead_indefinitely_after_failing() {
	val alice = finalize_seed_user(ft3_test.create_ft3_test_acc(util.alice_keypair()));
		
	val tx1 = rell.test
		.tx()
		.op(minter.mint_alice_seed(alice.address, "Ethereum", "1"))
		.sign(util.admin_keypair());
		
	rell.test
		.block()
		.tx(init())
		.tx(tx1)
		.run();
		
	val originals = get_originals_for_account(alice.account.id);
	var original_id = byte_array.from_gtv(originals[0].get("id")!!);
			
	val tx2 = rell.test
		.tx()
		.op(mysterious_seed.plant_seed(alice.account.id, alice.auth_descriptor, original_id))
		.sign(alice.keypair);
		
	rell.test
		.block()
		.tx(tx2)
		.run();
			
	val status = mysterious_seed.retrieve_plant_status(alice.account, time.days_from_now(524));
	
	assert_equals(status.status, "dead");
}

