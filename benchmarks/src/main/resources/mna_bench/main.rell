// Compute-only excerpts from chromaway/mna-blockchain (development @ 09617dc7), repackaged
// for the Rell runtime microbenchmarks. Three pure-compute workloads with shapes distinct
// from the ft4_bench three: decimal arithmetic via binary exponentiation + Padé/Taylor
// transcendentals, list-indexed Simplex noise summation, and rotation + AABB reduction
// over a list/set of integer-coordinate structs.

// ----------------------------------------------------------------------------
//  math/math.rell — power, integer_power, ln, ln_near_one, exp, ln2
// ----------------------------------------------------------------------------

function integer_power(base: decimal, exponent: integer): decimal {
    var result: decimal = 1.0;
    var b = base;
    var e = abs(exponent);
    while (e > 0) {
        if (e % 2 == 1) {
            result *= b;
        }
        b *= b;
        e /= 2;
    }
    return if (exponent < 0) 1.0 / result else result;
}

function ln_near_one(x: decimal): decimal {
    val y = x - 1;
    val y2 = y * y;
    val y3 = y2 * y;
    val y4 = y3 * y;
    val y5 = y4 * y;
    return y - y2 / 2 + y3 / 3 - y4 / 4 + y5 / 5;
}

function ln2(): decimal = 0.69314718055994530941;

function ln(x: decimal): decimal {
    if (x <= 0) return 0.0;
    if (x == 1) return 0;

    if (x > 0.9 and x < 1.1) {
        return ln_near_one(x);
    }

    var n = 0;
    var y = x;
    while (y >= 2) {
        y /= 2;
        n += 1;
    }
    while (y < 0.5) {
        y *= 2;
        n -= 1;
    }

    y -= 1;

    val a0 = 0.99999999999999999998;
    val a1 = 1.0000000000000000000;
    val b1 = 0.50000000000000000004;
    val b2 = 0.16666666666666666654;
    val b3 = 0.041666666666666666704;
    val b4 = 0.0083333333333333332177;

    val numerator = y * (a0 + a1 * y);
    val denominator = 1 + y * (b1 + y * (b2 + y * (b3 + b4 * y)));
    return (numerator / denominator) + n * ln2();
}

function exp(x: decimal): decimal {
    if (x == 0) return 1.0;
    if (x < 0) return 1.0 / exp(-x);

    var result = 1.0;
    var term = 1.0;
    var n = 1;
    while (abs(term) > 1e-15) {
        term *= x / n;
        result += term;
        n += 1;
    }
    return result;
}

function power(base: decimal, exponent: decimal): decimal {
    if (exponent == 0) return 1.0;
    if (base == 0) return 0.0;
    if (exponent < 0) return 1.0 / power(base, -exponent);

    if (exponent.floor() == exponent) {
        return integer_power(base, exponent.to_integer());
    }
    return exp(exponent * ln(base));
}

