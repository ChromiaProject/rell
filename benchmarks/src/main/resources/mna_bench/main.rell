function simplex_2d(
    perm_mod12: list<integer>,
    perm: list<integer>,
    grad3: list<integer>,
    x: decimal,
    y: decimal
): decimal {
    var n0 = 0.0;
    var n1 = 0.0;
    var n2 = 0.0;

    val s = (x + y) * F2;
    val i = (x + s).floor().to_integer();
    val j = (y + s).floor().to_integer();
    val t = (i + j) * G2;

    val X0 = i - t;
    val Y0 = j - t;
    val x0 = x - X0;
    val y0 = y - Y0;

    val i1 = if (x0 > y0) 1 else 0;
    val j1 = 1 - i1;

    val x1 = x0 - i1 + G2;
    val y1 = y0 - j1 + G2;
    val x2 = x0 - 1.0 + 2.0 * G2;
    val y2 = y0 - 1.0 + 2.0 * G2;

    var ii = i % 256;
    var jj = j % 256;
    if (ii < 0) ii += 256;
    if (jj < 0) jj += 256;

    var t0 = 0.5 - x0 * x0 - y0 * y0;
    if (t0 >= 0) {
        val gi0 = perm_mod12.get(ii + perm.get(jj));
        t0 *= t0;
        n0 = t0 * t0 * (grad3.get(gi0) * x0 + grad3.get(gi0 + 1) * y0);
    }

    var t1 = 0.5 - x1 * x1 - y1 * y1;
    if (t1 >= 0) {
        val gi1 = perm_mod12.get(ii + i1 + perm.get(jj + j1));
        t1 *= t1;
        n1 = t1 * t1 * (grad3.get(gi1) * x1 + grad3.get(gi1 + 1) * y1);
    }

    var t2 = 0.5 - x2 * x2 - y2 * y2;
    if (t2 >= 0) {
        val gi2 = perm_mod12.get(ii + 1 + perm.get(jj + 1));
        t2 *= t2;
        n2 = t2 * t2 * (grad3.get(gi2) * x2 + grad3.get(gi2 + 1) * y2);
    }

    return 70.0 * (n0 + n1 + n2);
}

function sum_octave_2d(
    perm_mod12: list<integer>,
    perm: list<integer>,
    grad3: list<integer>,
    iterations: integer,
    x: integer,
    y: integer,
    persistence: decimal,
    lacunarity: decimal,
    scale: decimal,
    low: integer,
    high: integer
): decimal {
    var max_amp = 0.0;
    var amp = 1.0;
    var freq = scale;
    var noise = 0.0;
    for (i in range(1, iterations + 1)) {
        noise += simplex_2d(perm_mod12, perm, grad3, x * freq, y * freq) * amp;
        max_amp += amp;
        amp *= persistence;
        freq *= lacunarity;
    }
    noise /= max_amp;
    noise = (noise * (high - low) / 2 + (high + low) / 2) - 2;
    return noise;
}

// ----------------------------------------------------------------------------
//  griddables/griddables.rell — location, grid_rotation, rotate*, area_for_locations
// ----------------------------------------------------------------------------

enum grid_rotation { north, east, south, west }

struct location {
    x: integer;
    y: integer;
}

function rotate_east(default_location: location): location =
    location(x = default_location.y, y = default_location.x * -1);

function rotate_south(default_location: location): location =
    location(x = default_location.x * -1, y = default_location.y * -1);

function rotate_west(default_location: location): location =
    location(x = default_location.y * -1, y = default_location.x);

function rotate(default_locations: list<location>, rotation: grid_rotation): list<location> {
    val resulting_relative_locations = list<location>();
    for (loc in default_locations) {
        resulting_relative_locations.add(
            when (rotation) {
                grid_rotation.north -> loc;
                grid_rotation.east -> rotate_east(loc);
                grid_rotation.south -> rotate_south(loc);
                grid_rotation.west -> rotate_west(loc);
            }
        );
    }
    return resulting_relative_locations;
}

// `integer.MAX_VALUE` isn't a Rell stdlib constant; use a finite sentinel that exceeds the
// bench grid (which never goes past ~10_000 on either axis) by many orders of magnitude.
val LOC_SENTINEL = 1000000000;

function area_for_locations(
    locations: set<location>,
    add_borders: boolean = false
): (from: location, to: location) {
    var min_x = LOC_SENTINEL;
    var min_y = LOC_SENTINEL;
    var max_x = -LOC_SENTINEL;
    var max_y = -LOC_SENTINEL;

    for (loc in locations) {
        if (loc.x < min_x) min_x = loc.x;
        if (loc.x > max_x) max_x = loc.x;
        if (loc.y < min_y) min_y = loc.y;
        if (loc.y > max_y) max_y = loc.y;
    }

    if (add_borders) {
        min_x -= 1;
        min_y -= 1;
        max_x += 1;
        max_y += 1;
    }

    return (from = location(x = min_x, y = min_y), to = location(x = max_x, y = max_y));
}

// ----------------------------------------------------------------------------
//  Benchmark entry points
// ----------------------------------------------------------------------------

// Decimal pow workload: alternates between integer-exponent (fast path: integer_power's
// repeated-squaring loop) and non-integer-exponent (slow path: exp(exponent * ln(base)),
// which exercises the Padé approximation of ln and the Taylor series expansion of exp).
query bench_decimal_pow(reps: integer): integer {
    var total = 0;
    var i = 0;
    while (i < reps) {
        // Integer exponent — exercises integer_power's binary exponentiation.
        val a = power(2.5, 17.0);
        // Non-integer exponent — exercises ln (Padé range-reduction) + exp (Taylor).
        val b = power(3.7, 4.25);
        // Fractional base near 1 — hits the ln_near_one Taylor path.
        val c = power(1.05, 6.5);
        // Negative exponent — exercises the reciprocal branch.
        val d = power(2.0, -5.0);
        total += (a + b + c + d).to_integer();
        i += 1;
    }
    return total;
}

// Perlin noise workload: 8-octave 2D simplex noise sampled across a 5x5 grid of points.
// Each sum_octave_2d call dispatches into simplex_2d, which performs ~12 list-indexed
// reads per sample plus mixed integer/decimal arithmetic — exactly the kind of hot
// inner loop that Truffle's partial evaluator should specialise.
query bench_perlin_noise(reps: integer): integer {
    val grad3 = GRAD3();
    val perm = PERM();
    val perm_mod12 = PERM_MOD12();
    val iterations = 8;
    val persistence = 0.5;
    val lacunarity = 2.0;
    val scale = 0.05;
    val low = 0;
    val high = 100;

    var total = 0;
    var i = 0;
    while (i < reps) {
        var x = 0;
        while (x < 5) {
            var y = 0;
            while (y < 5) {
                val noise = sum_octave_2d(
                    perm_mod12, perm, grad3, iterations, x, y,
                    persistence, lacunarity, scale, low, high
                );
                total += noise.to_integer();
                y += 1;
            }
            x += 1;
        }
        i += 1;
    }
    return total;
}

function bench_locations_input(): list<location> {
    val locs = list<location>();
    var i = 0;
    while (i < 64) {
        // Lissajous-ish pattern → varied (x, y) coordinates that stay finite.
        val x = ((i * 13) % 97) - 48;
        val y = ((i * 7 + 5) % 89) - 44;
        locs.add(location(x = x, y = y));
        i += 1;
    }
    return locs;
}

// Locations workload: rotate a 64-point list through all four cardinal rotations, then
// build a set<location> from each rotated copy and reduce it via area_for_locations.
// Stresses struct construction, list iteration with enum dispatch (when), set hashing
// for `location`, and integer min/max reduction.
query bench_locations(reps: integer): integer {
    val base = bench_locations_input();
    val rotations = [grid_rotation.north, grid_rotation.east, grid_rotation.south, grid_rotation.west];
    var total = 0;
    var i = 0;
    while (i < reps) {
        for (r in rotations) {
            val rotated = rotate(base, r);
            val rotated_set = set<location>();
            for (loc in rotated) {
                rotated_set.add(loc);
            }
            val area = area_for_locations(rotated_set, add_borders = true);
            total += area.to.x - area.from.x + area.to.y - area.from.y;
        }
        i += 1;
    }
    return total;
}
