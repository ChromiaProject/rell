function foo() {
    val ordered_products = product @* { .id in ordered_product_ids } (
        struct<product_order> (
            order = order,
            product = $,
            quantity = customer_order.products @ { $.id == .id }.quantity
        )
    );

    val ordered_products = product @* { .id in ordered_product_ids } (
        struct<product_order> (
            order = order,
            product = $,
            quantity = customer_order.products @ { $.id == .id } (
                .id == 2
            )
        )
    );

    var expected_result = assets.extract_data_from_transfer_history_list(
        assets.transfer_history_entry @* {
            acc.account @ { .id == alice.account.id }
        } ( @sort_desc @omit .rowid, $ ) limit 2
    );
}
