module;

entity ba_entity {
    key name;
    data: byte_array;
}

struct ba_struct {
    name;
    data: byte_array;
}

query ba_query(name): byte_array {
    return ba_entity @ { name } (.data);
}

query nullable_ba_query(name): byte_array? {
    return ba_entity @? { name } (.data);
}

operation ba_op(byte_array, ba_struct) { }
