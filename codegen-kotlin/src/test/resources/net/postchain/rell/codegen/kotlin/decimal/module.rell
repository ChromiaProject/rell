module;

entity decimal_entity {
    key name;
    data: decimal;
}

struct decimal_struct {
    name;
    data: decimal;
}

query decimal_query(name): decimal_struct {
    return decimal_entity @ { name } (decimal_struct(.name, .data));
}

operation decimal_op(d: decimal_struct) {
    create decimal_entity(d.name, d.data);
}
