module;

entity entity_entity {
    key name;
    data: byte_array;
}

struct entity_struct {
    name;
    data: byte_array;
    entity_entity;
}

query entity_query(name): entity_entity {
    return entity_entity @ { name };
}

query nullable_entity_query(name): entity_entity? {
    return entity_entity @? { name };
}

operation entity_op(entity_entity, e: entity_entity?, entity_struct) { }
